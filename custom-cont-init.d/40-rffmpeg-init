#!/usr/bin/with-contenv bash
set -euo pipefail

STATE_DIR="/var/lib/rffmpeg"
DB="${STATE_DIR}/rffmpeg.db"

mkdir -p "$STATE_DIR" /run/shm/rffmpeg /config/rffmpeg /config/temp
chown -R abc:abc "$STATE_DIR" /run/shm/rffmpeg /config/rffmpeg /config/temp || true
chmod 770 "$STATE_DIR" /run/shm/rffmpeg /config/temp || true

if [ ! -s "$DB" ]; then
  echo "**** initializing rffmpeg database ****"
  rffmpeg init --yes
else
  echo "**** rffmpeg database already exists; skipping init ****"
fi

# Optional: auto-add targets on first DB creation / empty hosts table.
# Set RFFMPEG_TARGETS="transcode1 192.168.1.50" or leave unset.
if [ -n "${RFFMPEG_TARGETS:-}" ]; then
  host_count="$(python3 - <<'PY'
import sqlite3
db = "/var/lib/rffmpeg/rffmpeg.db"
try:
    con = sqlite3.connect(db)
    print(con.execute("select count(*) from hosts").fetchone()[0])
except Exception:
    print(0)
PY
)"
  if [ "$host_count" = "0" ]; then
    for host in $RFFMPEG_TARGETS; do
      echo "**** adding rffmpeg target: $host ****"
      rffmpeg add --weight "${RFFMPEG_DEFAULT_WEIGHT:-1}" "$host"
    done
  else
    echo "**** rffmpeg hosts already configured; skipping target add ****"
  fi
fi
